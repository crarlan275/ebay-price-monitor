# ======================================================
# VARIABLES DE ENTORNO — ebay-price-monitor
# Copia este archivo como .env.local y completa los valores
# ======================================================

# --- eBay API (PENDIENTE: completar manualmente) ---
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_MARKETPLACE=EBAY_US

# --- Callmebot WhatsApp (PENDIENTE: completar manualmente) ---
CALLMEBOT_PHONE=+1234567890
CALLMEBOT_APIKEY=your_callmebot_apikey_here

# --- Seguridad Cron ---
CRON_SECRET=generate_a_secure_uuid_here

# --- Firebase Client SDK (obtener de Firebase Console > Configuración del proyecto) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin SDK (obtener de Firebase Console > Cuentas de servicio) ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
